{
  "manifest_version": 3,
  "name": "Research Assistant",
  "version": "1.1.0",
  "description": "Extract and verify factual claims from any text with transparent, cited evidence",
  "permissions": ["activeTab", "contextMenus", "storage"],
  "host_permissions": [
    "https://api.tavily.com/*",
    "https://api.exa.ai/*",
    "https://api.search.brave.com/*",
    "https://api.firecrawl.dev/*",
    "https://api.parallel.ai/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://huggingface.co/*",
    "https://cdn.jsdelivr.net/*",
    "https://nominatim.openstreetmap.org/*",
    "https://*.tile.openstreetmap.org/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Search Selected Text (Ctrl+Shift+F)",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Open Research Assistant popup"
    }
  }
}
