{
  "name": "live-fact-checker-extension",
  "version": "1.0.0",
  "description": "Chrome extension for live fact-checking using Tavily API",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,html,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,html,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint-staged": "lint-staged",
    "build": "npm run typecheck && vite build && node scripts/postbuild.mjs",
    "preview": "vite preview",
    "prepare": "cd .. && husky .husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.260",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.0.3",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.4",
    "prettier": "^3.5.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitest": "^2.1.9"
  }
}
